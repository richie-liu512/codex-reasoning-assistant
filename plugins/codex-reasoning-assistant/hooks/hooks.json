{
  "description": "Add the active Codex model and reasoning effort to each user turn.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$PLUGIN_ROOT/hooks/run_hook.sh\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& (Join-Path $env:PLUGIN_ROOT 'hooks\\run_hook.ps1')\"",
            "timeout": 5,
            "statusMessage": "Checking model and reasoning effort"
          }
        ]
      }
    ]
  }
}
